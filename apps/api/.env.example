# === Execution Mode ===
# default for local development: mock
# switch to hashkey_testnet explicitly when you want onchain demo execution
PAYMENT_EXECUTION_BACKEND=mock

# === HashKey Chain Testnet ===
HASHKEY_RPC_URL=https://testnet.hsk.xyz
HASHKEY_CHAIN_ID=133
HASHKEY_EXPLORER_BASE=https://testnet-explorer.hsk.xyz

# === Operator Wallet (DO NOT COMMIT) ===
HASHKEY_OPERATOR_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# === Contract (to be filled after deploy) ===
HASHKEY_PAYMENT_EXECUTOR_ADDRESS=

# === Token (optional, fill later) ===
HASHKEY_PAYMENT_TOKEN_ADDRESS=

# === Safe Mode (optional scaffold metadata) ===
HASHKEY_SAFE_ADDRESS=

# === Fiat-in / Stablecoin-out Settlement Quote (MVP deterministic) ===
SETTLEMENT_QUOTE_TTL_SECONDS=900
SETTLEMENT_SPREAD_BPS=45
SETTLEMENT_PLATFORM_FEE_BPS=30
SETTLEMENT_MIN_PLATFORM_FEE=0.10
SETTLEMENT_NETWORK_FEE=0.35
SETTLEMENT_FIAT_CHANNEL=stripe
SETTLEMENT_REQUIRE_KYC=true
SETTLEMENT_KYC_PROVIDER=stripe_identity
# demo shortcut: auto-verify KYC on /api/kyc/start (demo only)
SETTLEMENT_KYC_DEMO_MODE=false
# keep false by default; set true only for explicit demo/admin fallback
SETTLEMENT_ALLOW_MANUAL_MARK_RECEIVED_OVERRIDE=false

# === Stripe (Fiat Channel + KYC) ===
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/merchant?stripe=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/merchant?stripe=cancel
STRIPE_IDENTITY_RETURN_URL=http://localhost:3000/merchant?kyc=done
